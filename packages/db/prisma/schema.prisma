generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Chat {
  id      Int    @id @default(autoincrement())
  message String
  userId  String
  roomId  Int
  Room    Room   @relation(fields: [roomId], references: [id], onDelete: Cascade)
  Users   Users  @relation(fields: [userId], references: [id])
}

model Room {
  id                        Int      @id @default(autoincrement())
  slug                      String   @unique
  createdAt                 DateTime @default(now())
  adminId                   String
  Chat                      Chat[]
  Users_Room_adminIdToUsers Users    @relation("Room_adminIdToUsers", fields: [adminId], references: [id])
  Users_UserRooms           Users[]  @relation("UserRooms")
}

model Users {
  id                       String   @id
  username                 String?  @unique
  firstname                String
  lastname                 String
  email                    String   @unique
  password                 String
  createdAt                DateTime @default(now())
  phtotUrl                 String?
  Chat                     Chat[]
  Room_Room_adminIdToUsers Room[]   @relation("Room_adminIdToUsers")
  Room_UserRooms           Room[]   @relation("UserRooms")
}
